(footprint "TI_WL1837MOD"
  (version 20240101)
  (generator "pcbnew")
  (generator_version "9.0")
  (layer "F.Cu")
  (descr "TI WL1837MOD WiLink 8 WiFi/BT module, ~27.6x12.5mm stamp. Schematic pins 1-10 on bottom edge: VCC, GND, SDIO_CLK, SDIO_CMD, SDIO_D0-D3, WL_EN, ANT.")
  (tags "WiFi Bluetooth SDIO TI WiLink WL1837")
  (attr smd)

  (fp_text reference "REF**"
    (at 0 -7.5 0)
    (layer "F.SilkS")
    (effects (font (size 1 1) (thickness 0.15)))
  )
  (fp_text value "WL1837MOD"
